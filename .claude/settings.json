{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "network": {
      "allowedDomains": [
        "*.vercel.app"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/inject-docs.sh",
            "timeout": 10,
            "statusMessage": "Injetando docs do projeto..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-historico.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
